generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int        @id @default(autoincrement())
  name        String
  productType ProductType
  primer      String
  description String
  snapshot    String
  imageUrl    String
  images      String[]
  price       Float
  orientation Orientation
}

enum Orientation {
  portrait
  landscape
}

enum ProductType {
  poster
  tag
}

